# ──────────────────────────────────────────────────────────────────────────────
# SmartOLT Automate — installer env file (committed, safe defaults).
#
# Every value below is a deployable default — running
#   ./smartolt.sh install --yes
# on a fresh clone, with NO env vars set externally, will produce a
# working 5-service stack on a single host. Edit values after the
# install completes (./smartolt.sh install re-runs preserve .env unless
# SMARTOLT_OVERWRITE_ENV=Y).
#
# Sensitive values you SHOULD change before exposing the panel to
# the internet:
#   - INITIAL_ADMIN_PASSWORD  (a random one is auto-generated if left
#                              as the literal default; printed once)
#   - SMARTOLT_BASE_URL + SMARTOLT_API_KEY  (set from the panel after
#                              first login; the scheduler stays idle
#                              until you do)
# ──────────────────────────────────────────────────────────────────────────────

# ── SmartOLT tenant ────────────────────────────────────────────────────────────
# Leave these blank on first install — the panel will prompt for them.
# After the wizard creates .env, edit these values and the backend picks
# them up via the config_watcher (no restart needed).
SMARTOLT_BASE_URL=
SMARTOLT_API_KEY=
SMARTOLT_REQUEST_TIMEOUT=30
SMARTOLT_MAX_RETRIES=3

# ── Admin user (REQUIRED on first boot) ────────────────────────────────────────
# `admin` is the default login. The literal value "change-me-now" below
# is a sentinel: if install detects it (or empty) and runs non-interactive,
# it generates a random 20-char password and prints it at the end. To pin
# a password, set INITIAL_ADMIN_PASSWORD=<your-strong-password> (≥8 chars).
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-now

# ── Scheduler window ───────────────────────────────────────────────────────────
# Defaults: run the OLT reboot window at 02:00-03:00 in Bogota time.
# Edit SCHEDULER_TIMEZONE for your region; SCHEDULER_HOUR_START/END take
# integer hours in [0, 23] with SCHEDULER_HOUR_END > SCHEDULER_HOUR_START.
SCHEDULER_TIMEZONE=America/Bogota
SCHEDULER_HOUR_START=2
SCHEDULER_HOUR_END=3
SCHEDULER_MISFIRE_GRACE_SECONDS=300
TZ=America/Bogota

# ── Batching (defaults; will scale dynamically) ────────────────────────────────
# SmartOLT limits: 10 calls/s sustained, bursts >15/s blocked, 1000 calls/hour.
# Keep these conservative — the IP can be blocked.
BATCH_MIN_SIZE=10
BATCH_MAX_SIZE=50
BATCH_INITIAL_CONCURRENCY=1
BATCH_MAX_CONCURRENCY=3
BATCH_RAMP_UP_SECONDS=60
BATCH_RAMP_DOWN_SECONDS=60
BATCH_COOLDOWN_MS=500
BATCH_ERROR_BACKOFF_MULTIPLIER=1.5
BATCH_ERROR_THRESHOLD=0.02
BATCH_RATE_LIMIT_429_BACKOFF_SECONDS=10
OLT_STARTUP_STAGGER_SECONDS=15

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_PREFIX=smartolt-automate
LOG_JSON=false

# ── Persistence ────────────────────────────────────────────────────────────────
OLTS_CONFIG_PATH=configs/olts.yaml
STATE_DIR=state

# ── Web tier ───────────────────────────────────────────────────────────────────
WEB_PORT=8000
WEB_CORS_ORIGINS=http://localhost:5173,http://localhost
WEB_INTERNAL_BASE_URL=http://127.0.0.1:8080

# ── Reverse proxy (Caddy) — only used when public-access/SSL is enabled ───────
# Port 80 is intentionally NOT exposed (HTTPS-only by design).
PROXY_HTTPS_PORT=443

# ── Docker images (Docker Hub: asoton) ─────────────────────────────────────────
# These tags are pinned at the latest tested release. Override per host
# only if you've verified a newer tag works in your environment.
SMARTOLT_IMAGE=asoton/smartolt-automate:v0.3.3
SMARTOLT_FRONTEND_IMAGE=asoton/smartolt-automate-frontend:v0.3.3
PROXY_IMAGE=asoton/smartolt-automate-proxy:v0.3.3
CERTBOT_IMAGE=asoton/smartolt-automate-certbot:v0.3.3

# Pull policy: 'always' pulls on every 'up', 'missing'/'if_not_present'
# honours the local cache (use this in air-gapped installs).
PULL_POLICY=always

# ── JWT (auto-generated to data/jwt_secret if blank) ───────────────────────────
JWT_SECRET=
JWT_EXPIRY_HOURS=8
JWT_REFRESH_THRESHOLD_HOURS=1

# ── Internal API token shared between core scheduler and web tier ────────────
# Auto-generated by web on first boot and persisted to data/internal_token
# (default path below). The core reads the same file via the shared ./data
# volume. Leave blank unless you want a fixed value.
INTERNAL_API_TOKEN=
INTERNAL_API_TOKEN_FILE=data/internal_token

# ── Web hostname (as seen from the core container) ────────────────────────────
# Must match the docker-compose service name (default below).
WEB_SERVICE_NAME=smartolt-automate-web
WEB_INTERNAL_PORT=8000

# ── SSL renewal cron (hour-of-day in the scheduler timezone, comma-separated) ─
# The core scheduler triggers `certbot renew` at these hours. Certbot itself
# is idempotent — multiple checks per day are cheap and safe.
SSL_RENEW_HOUR=3,15
