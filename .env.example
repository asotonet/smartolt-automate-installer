# SmartOLT Automate — installer env file.
# Every value below is a deployable default. Run `./smartolt.sh install --yes`
# on a fresh clone, with no env vars set externally, to produce a working
# stack. Edit values after install completes.
#
# Sensitive values to change before exposing the panel:
#   - INITIAL_ADMIN_PASSWORD  (random generated if left as the default)
#   - SMARTOLT_BASE_URL + SMARTOLT_API_KEY  (set from the panel after login)

# SmartOLT tenant — leave blank, set from the panel after first login.
SMARTOLT_BASE_URL=
SMARTOLT_API_KEY=

# Admin user. `change-me-now` is a sentinel: install generates a random
# 20-char password and prints it when running non-interactive.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-now

# OLT reboot window. IANA timezone, integer hours with END > START.
SCHEDULER_TIMEZONE=America/Costa_Rica
SCHEDULER_HOUR_START=2
SCHEDULER_HOUR_END=3

# ── Deploy profile ────────────────────────────────────────────────────────────
# One of: lan | https-public | https-behind-external-proxy | frontend-only.
# Empty = inferred: PUBLIC_DOMAIN set → https-public, otherwise lan.
SMARTOLT_DEPLOY_PROFILE=

# ── Public access (HTTPS) — required for https-public, ignored otherwise ─────
SMARTOLT_PUBLIC_DOMAIN=
SMARTOLT_LETSENCRYPT_EMAIL=admin@example.com

# ── Traefik ─────────────────────────────────────────────────────────────────
TRAEFIK_DASHBOARD=false

# ── Docker images ────────────────────────────────────────────────────────────
SMARTOLT_IMAGE=asoton/smartolt-automate:v0.4.9
SMARTOLT_FRONTEND_IMAGE=asoton/smartolt-automate-frontend:v0.4.9
PROXY_IMAGE=asoton/smartolt-automate-traefik:v0.4.9
PULL_POLICY=always
