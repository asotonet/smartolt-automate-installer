# ──────────────────────────────────────────────────────────────────────────────
# SmartOLT Automate — installer env file (committed, safe defaults).
#
# Every value below is a deployable default — running
#   ./smartolt.sh install --yes
# on a fresh clone, with NO env vars set externally, produces a working
# 4-service stack on a single host. Edit values after the install completes
# (./smartolt.sh install re-runs preserve .env unless SMARTOLT_OVERWRITE_ENV=Y).
#
# Sensitive values you SHOULD change before exposing the panel:
#   - INITIAL_ADMIN_PASSWORD  (random one is auto-generated if left as the
#                              literal default; printed once at the end)
#   - SMARTOLT_BASE_URL + SMARTOLT_API_KEY  (set from the panel after first
#                              login; the scheduler stays idle until you do)
#
# For everything not listed here, the install wizard writes sane defaults.
# Override the rare advanced knob via a `docker-compose.override.yml`
# mounted on top of the service that owns it.
# ──────────────────────────────────────────────────────────────────────────────

# ── SmartOLT tenant ────────────────────────────────────────────────────────────
# Leave these blank on first install — the panel will prompt for them.
# After the wizard creates .env, edit these values; the backend picks them
# up via the config_watcher (no restart needed).
SMARTOLT_BASE_URL=
SMARTOLT_API_KEY=

# ── Admin user (REQUIRED on first boot) ────────────────────────────────────────
# `admin` is the default login. The literal value "change-me-now" is a
# sentinel: if install detects it (or empty) and runs non-interactive, it
# generates a random 20-char password and prints it at the end. To pin a
# password, set INITIAL_ADMIN_PASSWORD=<your-strong-password> (≥8 chars).
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-now

# ── Scheduler window ───────────────────────────────────────────────────────────
# Run the OLT reboot window at 02:00–03:00 in the configured timezone.
# SCHEDULER_TIMEZONE is an IANA name; SCHEDULER_HOUR_START/END take integer
# hours in [0, 23] with END > START.
SCHEDULER_TIMEZONE=America/Costa_Rica
SCHEDULER_HOUR_START=2
SCHEDULER_HOUR_END=3

# ── Public access (HTTPS) ──────────────────────────────────────────────────────
# Set SMARTOLT_PUBLIC_DOMAIN to enable real HTTPS via Let's Encrypt.
# The hostname's DNS A record MUST point at this host before ACME works.
# Required for the 'https-public' profile; ignored for the others.
SMARTOLT_PUBLIC_DOMAIN=
SMARTOLT_LETSENCRYPT_EMAIL=admin@example.com

# ── Deploy profile ─────────────────────────────────────────────────────────────
# A profile bundles (frontend exposure + Traefik presence + HTTPS source).
# The install wizard picks one; you can also pin it here to skip the prompt.
#
#   lan                              frontend on :8080 LAN, Traefik runs
#                                   but does NOT route (self-signed :443)
#   https-public                     frontend loopback, Traefik issues a
#                                   Let's Encrypt cert for SMARTOLT_PUBLIC_DOMAIN
#   https-behind-external-proxy      frontend loopback, NO Traefik container;
#                                   you run Caddy/Cloudflare Tunnel/nginx
#                                   outside the stack and point it at
#                                   http://127.0.0.1:8080
#   frontend-only                    frontend on :8080 LAN, NO Traefik, no HTTPS
#
# If empty, the wizard infers: SMARTOLT_PUBLIC_DOMAIN set -> https-public,
# otherwise lan. The three derived vars below (EXPOSE_FRONTEND_DIRECTLY,
# FRONTEND_BIND_IP, TRAEFIK_ENABLE) are written by the wizard and you
# normally don't need to touch them.
SMARTOLT_DEPLOY_PROFILE=

# EXPOSE_FRONTEND_DIRECTLY controls whether the frontend container publishes
# port :8080 on the host at all:
#   true  (LAN/test)    frontend reachable on http://HOST:8080/ directly.
#   false (production)  frontend is reachable ONLY via Traefik on :443.
# Auto-managed by the deploy profile; override only if you know what
# you're doing.
EXPOSE_FRONTEND_DIRECTLY=true

# ── Traefik ────────────────────────────────────────────────────────────────────
# Enable Traefik's web dashboard on :8081. Off by default (exposes internal
# state). The dashboard is bound to the host regardless of EXPOSE_FRONTEND_DIRECTLY.
TRAEFIK_DASHBOARD=false

# TRAEFIK_ENABLE is auto-managed by the deploy profile:
#   "true"  for https-public (Traefik routes by labels)
#   "false" for lan (Traefik runs but labels disable routing),
#            https-behind-external-proxy (no Traefik container),
#            and frontend-only (no Traefik container)
# Override only if you know what you're doing.

# ── Docker images (Docker Hub: asoton) ─────────────────────────────────────────
# Pinned at the latest tested release. Override per host only if you've
# verified a newer tag works in your environment.
SMARTOLT_IMAGE=asoton/smartolt-automate:v0.4.9
SMARTOLT_FRONTEND_IMAGE=asoton/smartolt-automate-frontend:v0.4.9
PROXY_IMAGE=asoton/smartolt-automate-traefik:v0.4.9

# Pull policy: 'always' pulls on every 'up'; 'missing'/'if_not_present'
# honours the local cache (use this in air-gapped installs).
PULL_POLICY=always